# Copy this file to .env and fill in your values
# Never commit .env to version control

# Required: get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: only needed if reporting.slack_enabled: true in brand.yaml
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Optional: only needed if setting mock_mode: false in brand.yaml
# TRUSTPILOT_API_KEY=your_trustpilot_api_key_here
# TRUSTPILOT_BUSINESS_UNIT_ID=your_business_unit_id_here
